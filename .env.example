# Redis
REDIS_URL=redis://localhost:6379

# Brightdata residential proxy (primary)
BRIGHTDATA_HOST=brd.superproxy.io
BRIGHTDATA_PORT=22225
BRIGHTDATA_USERNAME=brd-customer-XXXXXXXX-zone-residential
BRIGHTDATA_PASSWORD=XXXXXXXXXXXXXXXX

# Oxylabs residential proxy (fallback)
OXYLABS_HOST=pr.oxylabs.io
OXYLABS_PORT=7777
OXYLABS_USERNAME=customer-XXXXXX
OXYLABS_PASSWORD=XXXXXXXXXXXXXXXX

# Facebook Marketplace scraper account
# Store as a JSON-serialised cookie array from a logged-in browser session
FB_ACCOUNT_COOKIE=[]

# Health monitor port (per container)
HEALTH_MONITOR_PORT=9090
